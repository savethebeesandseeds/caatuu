{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caatuu.local/schemas/character-rig-v1.json",
  "title": "Caatuu layered character rig",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "character", "canvas", "origin", "bones", "layers", "contacts", "clips"],
  "properties": {
    "format": { "const": "caatuu-character-rig-v1" },
    "character": { "type": "string", "minLength": 1 },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "origin": { "$ref": "#/$defs/point" },
    "bones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "pivot"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "parent": { "type": ["string", "null"] },
          "pivot": { "$ref": "#/$defs/point" },
          "z": { "type": "integer", "default": 0 },
          "optional": { "type": "boolean", "default": false }
        }
      }
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "bone", "src", "z", "size", "pivot"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "bone": { "type": "string", "minLength": 1 },
          "src": { "type": "string", "minLength": 1 },
          "z": { "type": "integer" },
          "size": { "$ref": "#/$defs/size" },
          "pivot": { "$ref": "#/$defs/point" },
          "rest": { "$ref": "#/$defs/transform" }
        }
      }
    },
    "contacts": {
      "type": "object",
      "minProperties": 2,
      "additionalProperties": { "$ref": "#/$defs/contact" }
    },
    "clips": {
      "type": "object",
      "required": ["standing", "starting", "walking", "arriving"],
      "additionalProperties": { "$ref": "#/$defs/clip" }
    }
  },
  "$defs": {
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "transform": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number", "default": 0 },
        "y": { "type": "number", "default": 0 },
        "rotation": { "type": "number", "default": 0 },
        "scaleX": { "type": "number", "default": 1 },
        "scaleY": { "type": "number", "default": 1 }
      }
    },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bone", "point"],
      "properties": {
        "bone": { "type": "string" },
        "point": { "$ref": "#/$defs/point" },
        "optional": { "type": "boolean", "default": false }
      }
    },
    "clip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["durationMs", "loop", "channels"],
      "properties": {
        "durationMs": { "type": "number", "exclusiveMinimum": 0 },
        "loop": { "type": "boolean" },
        "distanceDriven": { "type": "boolean", "default": false },
        "channels": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["at", "value"],
              "properties": {
                "at": { "type": "number", "minimum": 0, "maximum": 1 },
                "value": { "type": "number" },
                "ease": { "enum": ["linear", "smooth", "ease-in", "ease-out"] }
              }
            }
          }
        }
      }
    }
  }
}
