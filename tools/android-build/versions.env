#!/usr/bin/env bash

ANDROID_SDK_ROOT="${ANDROID_SDK_ROOT:-/opt/android-sdk}"
ANDROID_HOME="${ANDROID_HOME:-$ANDROID_SDK_ROOT}"

ANDROID_CMDLINE_TOOLS_VERSION="${ANDROID_CMDLINE_TOOLS_VERSION:-14742923}"
ANDROID_CMDLINE_TOOLS_SHA1="${ANDROID_CMDLINE_TOOLS_SHA1:-48833c34b761c10cb20bcd16582129395d121b27}"
ANDROID_COMPILE_SDK="${ANDROID_COMPILE_SDK:-36}"
ANDROID_BUILD_TOOLS_VERSION="${ANDROID_BUILD_TOOLS_VERSION:-36.0.0}"
ANDROID_FALLBACK_BUILD_TOOLS_VERSION="${ANDROID_FALLBACK_BUILD_TOOLS_VERSION:-35.0.0}"
ANDROID_NDK_VERSION="${ANDROID_NDK_VERSION:-29.0.13113456}"
ANDROID_CMAKE_VERSION="${ANDROID_CMAKE_VERSION:-3.31.6}"

JDK_HOME="${JDK_HOME:-/opt/jdk-17}"
JDK_DOWNLOAD_URL="${JDK_DOWNLOAD_URL:-https://api.adoptium.net/v3/binary/latest/17/ga/linux/x64/jdk/hotspot/normal/eclipse?project=jdk}"
GRADLE_VERSION="${GRADLE_VERSION:-8.14.3}"
GRADLE_HOME="${GRADLE_HOME:-/opt/gradle/gradle-$GRADLE_VERSION}"

export ANDROID_SDK_ROOT
export ANDROID_HOME
export JDK_HOME
export JDK_DOWNLOAD_URL
if [ -x "$JDK_HOME/bin/java" ]; then
  export JAVA_HOME="$JDK_HOME"
  export PATH="$JAVA_HOME/bin:$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/platform-tools:$GRADLE_HOME/bin:$PATH"
else
  export PATH="$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/platform-tools:$GRADLE_HOME/bin:$PATH"
fi
